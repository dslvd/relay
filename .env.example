# Cloudflare R2 (storage backend)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Cloudflare D1 (analytics)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=

# Supabase (Plus accounts / relational data)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (rate limiting / caching)
REDIS_URL=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Auth / secrets
ADMIN_PASSWORD=
PLUS_INVITE_SECRET=
CRON_SECRET=

# Abuse scanning
VIRUSTOTAL_API_KEY=

# App config
NEXT_PUBLIC_BASE_URL=http://localhost:3000
MAX_UPLOAD_FILE_MB=100
R2_STORAGE_USD_PER_GB_MONTH=
R2_EGRESS_USD_PER_GB=

# Sentry (optional — error reporting stays inert until these are set)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
